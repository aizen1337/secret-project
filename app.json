{
  "expo": {
    "scheme": "myapp",
    "plugins": [
      "expo-router",
      "expo-maps",
      "expo-web-browser",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.secretproject",
          "enableGooglePay": true
        }
      ]
    ],
    "name": "secret-project",
    "slug": "secret-project",
    "web": {
      "bundler": "metro"
    },
    "userInterfaceStyle": "automatic"
  }
}
