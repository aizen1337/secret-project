# Keep backend/dashboard tag aligned. Use "latest" unless you pin to an existing tag on both images.
REV=latest

PORT=3210
SITE_PROXY_PORT=3211
DASHBOARD_PORT=6791

# Required.
# Must be 64 hex chars. Generate with e.g.:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Admin key (for CLI) is generated after first boot:
# docker compose -f infra/convex-selfhost/docker-compose.yml --env-file infra/convex-selfhost/.env exec backend ./generate_admin_key.sh
INSTANCE_SECRET=replace_with_64_hex_chars

# Optional tuning knobs for load/race experiments.
APPLICATION_MAX_CONCURRENT_MUTATIONS=128
APPLICATION_MAX_CONCURRENT_QUERIES=512
APPLICATION_MAX_CONCURRENT_NODE_ACTIONS=64
APPLICATION_MAX_CONCURRENT_V8_ACTIONS=64
RUST_LOG=info

# Renter verification provider (local-first Poland flow)
VERIFICATION_PROVIDER_DEFAULT=poland_local
POLAND_VERIFICATION_API_BASE_URL=http://verification-provider:9000/v1
POLAND_VERIFICATION_API_KEY=replace_me
POLAND_VERIFICATION_RETURN_URL=http://127.0.0.1:8081/profile?verification=return
POLAND_VERIFICATION_ENABLE_MOBYWATEL=false
POLAND_VERIFICATION_ENABLE_OCR_FALLBACK=true
POLAND_VERIFICATION_RECERT_DAYS=30
