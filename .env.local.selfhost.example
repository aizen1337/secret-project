# Self-hosted profile example
CONVEX_DEPLOYMENT=self-hosted
EXPO_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace_me
LOADTEST_MODE=true

EXPO_PUBLIC_BETTER_AUTH_URL=http://127.0.0.1:3210/api/auth
BETTER_AUTH_URL=http://127.0.0.1:3210/api/auth
BETTER_AUTH_SECRET=replace_with_long_random_secret
BETTER_AUTH_TRUSTED_ORIGIN=myapp://
BETTER_AUTH_GOOGLE_CLIENT_ID=replace_me
BETTER_AUTH_GOOGLE_CLIENT_SECRET=replace_me
BETTER_AUTH_APPLE_CLIENT_ID=replace_me
BETTER_AUTH_APPLE_CLIENT_SECRET=replace_me
BETTER_AUTH_FACEBOOK_CLIENT_ID=replace_me
BETTER_AUTH_FACEBOOK_CLIENT_SECRET=replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
EXPO_PUBLIC_STRIPE_KEY=pk_test_replace_me
ENABLE_RENTER_VERIFICATION=false
VERIFICATION_PROVIDER_DEFAULT=poland_local
POLAND_VERIFICATION_API_BASE_URL=http://127.0.0.1:9000/v1
POLAND_VERIFICATION_API_KEY=replace_me
POLAND_VERIFICATION_RETURN_URL=http://127.0.0.1:8081/profile?verification=return
POLAND_VERIFICATION_ENABLE_MOBYWATEL=false
POLAND_VERIFICATION_ENABLE_OCR_FALLBACK=true
POLAND_VERIFICATION_RECERT_DAYS=30
